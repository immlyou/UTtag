# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=eyJ...your-service-role-key

# Anon key — only required to activate S5 user-scoped RLS enforcement
# (see DEPLOY.md §"S5 RLS enforcement"). Without it lib/supabase.js falls
# back to the service client for every caller (today's behaviour).
# SUPABASE_ANON_KEY=eyJ...your-anon-public-key

# JWT（必填，缺少時應用程式會拒絕啟動）
# For S5 full RLS, set this to the same value as Supabase's project
# JWT secret (Supabase dashboard → Settings → API → JWT Secret) so
# PostgREST can validate our tokens and populate request.jwt.claims.
JWT_SECRET=your-random-secret-at-least-32-chars

# CORS（選填，逗號分隔的允許來源。未設定時允許所有來源）
# ALLOWED_ORIGINS=https://yourdomain.com,https://admin.yourdomain.com

# UTTEC API
# UTTEC_API_KEY=your-uttec-api-key

# Email Service (Resend)
RESEND_API_KEY=re_your_api_key
EMAIL_FROM=UTtag <reports@yourdomain.com>
APP_URL=https://yourdomain.com

# Scheduler
ENABLE_SCHEDULER=true

# Push Notifications (Firebase Cloud Messaging)
ENABLE_PUSH=true
FIREBASE_PROJECT_ID=your-firebase-project-id
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your-project.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYour private key here\n-----END PRIVATE KEY-----\n"
